# secret-proxy namespace: michael
#
# This file is mounted by a 1Password Environment specific to the "michael"
# project/context. The proxy reads resolved secret values — not op:// references.
#
# To set up:
# 1Password Desktop → Developer → Environments → "michael"
# Add variables there (1Password resolves op:// refs at mount time)
# Destinations → Local .env file → ~/.config/secret-proxy/namespaces/michael/secrets.env
#
# Clients reference these secrets with the namespace prefix:
#   {{michael:ANTHROPIC_API_KEY}}
#
# Each secret MUST have a corresponding _HOSTS variable.

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_API_KEY_HOSTS=api.anthropic.com

# OpenAI API
OPENAI_API_KEY=sk-proj-...
OPENAI_API_KEY_HOSTS=api.openai.com
