# secret-proxy default secrets configuration
#
# This file is mounted by 1Password Environments as a UNIX named pipe.
# The proxy reads resolved secret values — not op:// references.
#
# To set up:
# 1Password Desktop → Developer → Environments → Your Environment
# Add variables there (1Password resolves op:// refs at mount time)
# Destinations → Local .env file → ~/.config/secret-proxy/secrets.env
#
# Clients reference these with plain placeholders: {{SECRET_NAME}}
# For per-project secrets, use namespaces instead: {{namespace:SECRET_NAME}}
# See namespaces/*/secrets.env.example for namespace configuration.
#
# IMPORTANT: Each secret MUST have a corresponding _HOSTS variable
# defining which hosts are allowed to receive it. Requests to other
# hosts will be blocked.

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_API_KEY_HOSTS=api.anthropic.com

# OpenAI API
OPENAI_API_KEY=sk-proj-...
OPENAI_API_KEY_HOSTS=api.openai.com

# GitHub (multiple hosts allowed, comma-separated)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN_HOSTS=api.github.com,github.com,uploads.github.com

# Example: Custom internal service
# MY_SERVICE_TOKEN=tok_xxxxxxxxxxxxxxxx
# MY_SERVICE_TOKEN_HOSTS=api.myservice.com,staging.myservice.com

# Example: Derived secret (Apple Music JWT)
# The proxy generates a short-lived JWT from these component secrets.
# No APPLE_MUSIC_TOKEN value is needed — the _GENERATOR tells the proxy
# to compute it on the fly.
# APPLE_MUSIC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGT...
# APPLE_MUSIC_KEY_ID=ABC123DEFG
# APPLE_MUSIC_TEAM_ID=9876543210
# APPLE_MUSIC_TOKEN_GENERATOR=apple_music_jwt
# APPLE_MUSIC_TOKEN_HOSTS=api.music.apple.com
